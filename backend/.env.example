# Cachy backend configuration. Copy to .env and fill what you have.
# Everything has a sane default; the app boots and completes jobs with NO keys
# (Whisper skipped, structuring falls back to a deterministic paragraph card).

# --- storage ---
DATABASE_URL=sqlite+aiosqlite:///./cachy.db
MEDIA_DIR=./downloads

# --- transcription ---
# WHISPER_BACKEND: none | groq  (local faster-whisper not used on free HF CPU)
WHISPER_BACKEND=groq
GROQ_API_KEY=
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# --- structuring LLM ---
# LLM_BACKEND: huggingface | groq | none  (which model structures the card)
# huggingface = free HF Inference Providers (Qwen2.5-72B-Instruct), credit-capped monthly.
LLM_BACKEND=huggingface
HF_API_KEY=
HF_MODEL=Qwen/Qwen2.5-72B-Instruct

# --- ingestion ---
RAPIDAPI_KEY=
COOKIES_PATH=

# --- worker / queue ---
MAX_ATTEMPTS=3
WORKER_POLL_SECONDS=1.0
JOB_TIMEOUT_SECONDS=300

# --- misc ---
# Discard the source video after extraction (keep only keyframes+thumbnail).
DISCARD_SOURCE_VIDEO=true

# Cachy backend config. Copy to .env and fill keys. Every external dep is
# optional — the app degrades gracefully when a key is absent.

# --- storage ---
DATABASE_URL=
MEDIA_DIR=./downloads

# --- transcription (audio -> text) ---
# WHISPER_BACKEND: groq (Groq Whisper API) | local (faster-whisper, no API/limits) | none
WHISPER_BACKEND=groq
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
# local model size: tiny=39MB | base=74MB | small=244MB (used when WHISPER_BACKEND=local)
LOCAL_WHISPER_MODEL=base

# --- note generation (structuring) ---
# Stage 1 preprocess: Gemini Flash Lite (500 RPD, separate quota) dedupe + strip filler
# Stage 2 structure:  Gemini primary (see bottom) -> Cerebras llama-3.3-70b (60k TPM) -> Groq fallback
CEREBRAS_API_KEY=
CEREBRAS_LLM_MODEL=gpt-oss-120b
GROQ_LLM_MODEL=llama-3.3-70b-versatile
# verify exact id in Gemini console (e.g. gemini-3.1-flash-lite); reuses GEMINI_JK
GEMINI_PREPROCESS_MODEL=gemini-flash-lite-latest
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- vision (carousel/slide OCR): Gemini (GEMINI_JK) primary -> Groq fallback -> local Tesseract ---
GEMINI_VISION_MODEL=gemini-2.0-flash-lite
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- shared Groq key (whisper + structuring fallback + vision fallback) ---
GROQ_API_KEY=

# --- ingestion ---
RAPIDAPI_KEY=
COOKIES_PATH=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- worker / queue ---
MAX_ATTEMPTS=3
WORKER_POLL_SECONDS=1.0
JOB_TIMEOUT_SECONDS=300

# --- misc ---
DISCARD_SOURCE_VIDEO=true

# Gemini — 7 named accounts (free tier ~20 RPD/key on 2.5-flash)
GEMINI_JK=      # preprocess (bundle cleanup) + vision (OCR/frame reads)
GEMINI_KVA=     # primary — structuring/insight (every card) + concept define + catalog describe
GEMINI_VPN=     # pool — fallback behind GEMINI_KVA when it's quota-exhausted
GEMINI_VVA=     # pool
GEMINI_VV=      # pool
GEMINI_D08=     # pool
GEMINI_DVU=     # pool
GEMINI_LLM_MODEL=gemini-2.5-flash

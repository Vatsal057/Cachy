<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext (HTTP) traffic so physical mobile devices on the local LAN can connect to dev servers over HTTP (e.g. http://192.168.x.x:8000). Production deployments (e.g., HuggingFace Spaces) use HTTPS. -->
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
